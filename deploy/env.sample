# =============================================================================
# EXRA — Production Environment Template
# После деплоя: скопировать на сервер как /etc/exra.env, заполнить РЕАЛЬНЫМИ
# значениями, затем `systemctl restart exra.service`.
#
# NEVER commit this file with real values.
# =============================================================================

# --- Control plane port ---
CONTROL_PORT=8081

# --- Database (Supabase / Postgres) ---
SUPABASE_URL=postgres://exra:REPLACE_PG_PASSWORD@localhost:5432/exra?sslmode=disable

# --- Redis ---
REDIS_URL=redis://localhost:6379

# =============================================================================
# AUDIT v2.4.1 — REQUIRED VARS (P0 / P1 fixes rely on these)
# =============================================================================

# D3 — WebSocket CSRF defence. Whitelist of allowed Origin headers.
# Comma-separated, NO spaces. Request from any other origin is dropped.
WS_ALLOWED_ORIGINS=https://app.exra.io,https://dashboard.exra.io,https://exra.io

# D1 — Asymmetric JWT (Ed25519 / EdDSA). Gateway can ONLY verify, Control
# Plane signs. Symmetric NODE_SECRET path is retired for new tokens.
# Generate once:
#   openssl genpkey -algorithm Ed25519 -out priv.pem
#   openssl pkey -in priv.pem -pubout -out pub.pem
# Then strip PEM headers and paste the raw base64 (or hex) below.
GATEWAY_JWT_PUBLIC_KEY=REPLACE_WITH_EDDSA_PUBLIC_KEY_HEX
GATEWAY_JWT_PRIVATE_KEY=REPLACE_WITH_EDDSA_PRIVATE_KEY_HEX

# F1 — Oracle signature before 2/3 consensus. Sr25519 seed for PEAQ oracle.
# Must match the oracle account registered on-chain in peaq pallet.
PEAQ_ORACLE_SEED=REPLACE_WITH_SR25519_SEED_OR_MNEMONIC

# --- Transitional (remove after full DID migration) ---
NODE_SECRET=REPLACE_WITH_HEX_SECRET
PROXY_SECRET=REPLACE_WITH_HEX_SECRET

# =============================================================================
# PEAQ L1 Connectivity
# =============================================================================
PEAQ_RPC=wss://peaq.api.onfinality.io/public-ws
ORACLE_NODES=3
FEEDER_STAKE_MIN=10
TIMELOCK_ANON=24h

# =============================================================================
# Tokenomics (policy finalized in production)
# =============================================================================
EXRA_MAX_SUPPLY=1000000000
POP_EMISSION_PER_HEARTBEAT=0.000050
RATE_PER_GB=0.30
EXRA_POLICY_FINALIZED=true

# =============================================================================
# Payout rails (multi-chain)
# =============================================================================
TON_RPC_URL=https://toncenter.com/api/v2/jsonRPC
TON_API_KEY=REPLACE_WITH_TON_API_KEY
JETTON_MASTER_ADDRESS=REPLACE_WITH_JETTON_MASTER
TON_WALLET_ADDRESS=REPLACE_WITH_PAYOUT_WALLET

# =============================================================================
# Dashboard / Landing (Next.js public vars — safe to expose)
# =============================================================================
NEXT_PUBLIC_SUPABASE_URL=https://ymytnxamelpdvrnczhee.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_C_PqDyPasl0bnafsHx8fOg_UrV_ZYOd
NEXT_PUBLIC_API_BASE_URL=
