# Exra Network - Production Environment Template (v2.2)
# Copy this to .env and fill in the secrets.

# --- INFRASTRUCTURE ---
PORT=8080
CONTROL_PORT=8081
SUPABASE_URL=https://your-project.supabase.co
REDIS_URL=redis://localhost:6379
DB_MAX_OPEN_CONNS=50
LOG_LEVEL=info

# --- SECURITY ---
# IMPORTANT: Generate unique secrets for production!
NODE_SECRET=change-this-unique-node-secret
PROXY_SECRET=change-this-unique-proxy-secret
ADMIN_SECRET=change-this-unique-admin-root-secret
GATEWAY_JWT_SECRET=change-this-high-entropy-jwt-secret

# --- PEAQ DePIN ---
PEAQ_RPC=https://rpc.krest.peaq.network
ORACLE_NODES=3
FEEDER_STAKE_MIN=10
TIMELOCK_ANON=24h
PEAQ_ORACLE_SEED=// your-sr25519-oracle-seed-here

# --- GATEWAY & MATCHER ---
GATEWAY_URL=wss://gateway.exra.network/gateway
MAX_NODES_PER_IP=5

# --- ECONOMICS ---
RATE_PER_GB=0.30
POP_EMISSION_PER_HEARTBEAT=0.000050
EXRA_MAX_SUPPLY=1000000000
EXRA_POLICY_FINALIZED=true

# --- COMPUTE MARKET ---
TASK_TIMEOUT_MINUTES=10
RS_PENALTY_FAILURE=50

# --- TELEGRAM ---
# Required for TMA (Telegram Mini App) auth. Get from @BotFather.
TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather

# --- GEOLOCATION ---
# Download GeoLite2-City.mmdb from MaxMind
GEO_DB_PATH=GeoLite2-City.mmdb
